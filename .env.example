# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE de variáveis de ambiente — copie para .env e preencha os valores.
# Este arquivo É commitado no GitHub (sem valores reais).
# ─────────────────────────────────────────────────────────────────────────────

# Mapbox — token de acesso para o mapa de rotas
# Crie em: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiREVVX1VTVUFSSUoiLCJhIjoiREVVX1RPS0VOfQ.EXEMPLO

# URL base da API backend (sem barra no final, sem https://)
# Em produção: domínio do Azure Web App
VITE_API_URL=challengesprint.azurewebsites.net

# ── EmailJS (lembretes de consulta) ──────────────────────────────────────────
# Crie conta em https://emailjs.com, configure um serviço e dois templates.
# Deixe vazio para desativar o envio real (a UI de lembretes ainda aparece).
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_CONFIRMACAO=template_xxxxxxx
VITE_EMAILJS_TEMPLATE_LEMBRETE=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
